{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/motor.ts": { "maxDuration": 60 },
    "api/render.ts": { "maxDuration": 60 },
    "api/calcular-orcamento.ts": { "maxDuration": 30 },
    "api/agent.ts": { "maxDuration": 60 },
    "api/analisar-planta.ts": { "maxDuration": 30 },
    "api/pdf-orcamento.ts": { "maxDuration": 30 },
    "api/lista-corte.ts": { "maxDuration": 30 },
    "api/vision.ts": { "maxDuration": 30 },
    "api/ai.ts": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
