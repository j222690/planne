# ─── Supabase ────────────────────────────────────────────────
# Exposto ao cliente (prefixo VITE_)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ─── IA: Groq (primário — grátis em groq.com) ────────────────
# SEM prefixo VITE_ — acessado apenas pelo servidor
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── IA: OpenAI GPT-4o mini (fallback) ───────────────────────
# SEM prefixo VITE_ — acessado apenas pelo servidor
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Render de interiores: Flux API (Black Forest Labs) ───────
# Opcional — sem esta chave, usa DALL-E como fallback
# Schnell: preview rápido (async, ~4s) · Pro: render premium (async, ~30s)
# Obtenha em: api.bfl.ml
FLUX_API_KEY=
